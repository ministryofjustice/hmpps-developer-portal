{
  "name": "hmpps-developer-portal",
  "version": "0.0.1",
  "description": "Hmpps Developer Portal",
  "repository": "git@github.com:ministryofjustice/hmpps-developer-portal.git",
  "license": "MIT",
  "scripts": {
    "build": "node esbuild/esbuild",
    "clean": "rm -rf dist build node_modules",
    "int-test-ui": "playwright test --ui",
    "int-test": "playwright test",
    "lint-fix": "eslint .  --cache --max-warnings 0 --fix",
    "lint": "eslint . --cache --max-warnings 0",
    "prepare": "hmpps-precommit-hooks-prepare",
    "rebuild": "npm run clean && npm i && npm run build",
    "security_audit": "npx audit-ci --config audit-ci.json",
    "setup": "npm ci && hmpps-npm-script-run-allowlist",
    "start-feature:dev": "node esbuild/esbuild --watch --env feature.env",
    "start-feature": "export $(cat feature.env) && node $NODE_DEBUG_OPTION dist/server.js | bunyan -o short",
    "start:dev": "node esbuild/esbuild --watch",
    "start": "node $NODE_OPTIONS dist/server.js | bunyan -o short",
    "test:ci": "jest --runInBand",
    "test": "jest",
    "typecheck": "tsc && tsc -p integration_tests"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "dependencies": {
    "@ministryofjustice/frontend": "^9.0.0",
    "@ministryofjustice/hmpps-monitoring": "2.1.0",
    "agentkeepalive": "^4.6.0",
    "applicationinsights": "^2.9.8",
    "bunyan": "^1.8.15",
    "bunyan-format": "^0.2.1",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-redis": "^9.0.0",
    "csrf-sync": "^4.2.1",
    "datatables.net": "^2.3.8",
    "datatables.net-buttons": "^3.2.6",
    "datatables.net-buttons-dt": "^3.2.6",
    "datatables.net-dt": "^2.3.8",
    "datatables.net-searchpanes": "^2.3.5",
    "datatables.net-select": "^3.1.3",
    "dayjs": "^1.11.21",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "govuk-frontend": "6.4.0",
    "helmet": "^8.3.0",
    "http-errors": "^2.0.1",
    "jquery": "^4.0.0",
    "js-base64": "^3.9.1",
    "jszip": "3.10.1",
    "mermaid": "^11.16.0",
    "nocache": "^4.0.0",
    "nunjucks": "^3.2.4",
    "pako": "^3.0.1",
    "redis": "^6.1.0",
    "superagent": "^10.3.0",
    "svg-pan-zoom": "^3.6.2",
    "url-value-parser": "^2.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@jgoz/esbuild-plugin-typecheck": "^4.0.4",
    "@ministryofjustice/eslint-config-hmpps": "^1.0.3",
    "@ministryofjustice/hmpps-npm-script-allowlist": "0.0.6",
    "@ministryofjustice/hmpps-precommit-hooks": "^3.0.1",
    "@playwright/test": "1.61.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/bunyan": "^1.8.11",
    "@types/bunyan-format": "^0.2.9",
    "@types/compression": "^1.8.1",
    "@types/connect-flash": "0.0.40",
    "@types/cookie-session": "^2.0.49",
    "@types/express-session": "^1.19.0",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.3",
    "@types/nunjucks": "^3.2.6",
    "@types/pako": "^2.0.4",
    "@types/superagent": "^8.1.11",
    "@types/supertest": "^7.2.1",
    "audit-ci": "^7.1.0",
    "axe-core": "^4.12.1",
    "cheerio": "1.2.0",
    "cookie-session": "^2.1.1",
    "del": "^8.0.1",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-manifest": "^1.0.5",
    "esbuild-sass-plugin": "^3.7.0",
    "jest": "^30.4.2",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^17.0.0",
    "lint-staged": "^17.0.8",
    "nock": "^14.0.16",
    "prettier": "^3.9.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@opentelemetry/core": "2.9.0",
    "brace-expansion": "5.0.7",
    "mocha": {
      "diff": "^8.0.4",
      "serialize-javascript": "^7.0.7"
    }
  }
}

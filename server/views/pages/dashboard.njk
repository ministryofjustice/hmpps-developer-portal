{% extends "../partials/layout.njk" %}

{% from "govuk/components/input/macro.njk" import govukInput %}
{%- from "moj/components/search/macro.njk" import mojSearch -%}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/details/macro.njk" import govukDetails %}
{%- from "moj/components/alert/macro.njk" import mojAlert -%}
{%- from "moj/components/badge/macro.njk" import mojBadge -%}

{% set pageTitle = applicationName + " - Dashboard" %}
{% set mainClasses = "app-container govuk-body" %}

{% block content %}
  {{ breadCrumb("Dashboard", []) }}

  {% if dashboard.usersCookiePrefs == 'yes' %}
  <form action="/dashboard/name" method="POST">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    {% if dashboard.name %}
      <h1 id="welcome-known-user-heading">Welcome to your dashboard, {{ dashboard.name }}</h1>
    {% else %}
      <h1 id="welcome-unknown-user-heading">Welcome to your dashboard, </h1>
      {{ govukInput({
        label: {
        text: "Please enter your name",
        classes: "govuk-label--m"
        },
        id: "dashboard-user-name",
        name: "name"
      }) }}
    {% endif %}
  </form>

  {% if dashboard.error == "notfound" %}
  {{ mojAlert({
      variant: "error",
      title: attemptedProduct,
      showTitleAsHeading: true,
      dismissible: false,
      text: dashboard.attemptedProduct + " is not a valid product name. See full list below to find your product ('See full list of products')"
    }) }}
  {% endif %}

  {% if dashboard.error == "empty" %}
    <p class= "error-message">Please enter a product name</p>
  {% endif %}

  <form action="/dashboard/saved-products/add" method="POST" style="margin-bottom: 15px">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
  {{ mojSearch({
    action: "#",
    method: "post",
    input: {
      id: "search-products",
      name: "product"
    },
    label: {
      text: "Find a product",
      classes: "govuk-!-font-weight-bold"
    },
    button: {
      text: "Add a product",
      id: "add-product-button"
    }
  }) }}

    {% macro deleteButton(product) %}
      <form action="/dashboard/saved-products/delete" method="POST">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <input type="hidden" name="delete" value="{{ product | string }}">
        {{ govukButton({
            type: "submit",
            text: "Remove Product"
        }) }}
      </form>
  {% endmacro %}

  {% macro allProductsList(products) %}
    <ul>
      {% for product in dashboard.products %}
        <li>{{ product.name }}</li>
      {% endfor %}
    </ul>
  {% endmacro %}

 {% macro componentsList(componentsInfo)%}
    {% if dashboard.component | length %}
      <ul>
        {% for details in componentsInfo %}
          <li>
            <a data-test="component-link" href="/components/{{ details.name }}">
              {{ details.name }}{% if details.archived == true %} (ARCHIVED){% endif %}
            </a>
              {% for name in dashboard.alerts %}
                {% if name.componentSlug == details.name %}{{ mojBadge({ text: "Active Alert", classes: "moj-badge--red" }) }} {% endif %}
              {% endfor %}
              {% for name in dashboard.veracodeComponentName %}
                {% if name == details.name %}{{ mojBadge({ text: "Veracode", classes: "moj-badge--purple" }) }} {% endif %}
              {% endfor %}
              {% for name in upgradeNeeded %}
                {% if name == details.name %}{{ mojBadge({ text: "Upgrade needed", classes: "moj-badge--blue" }) }} {% endif %}
              {% endfor %}
          </li>
    {% else %}
      <li>None</li>
        {% endfor %}
      </ul>
    {% endif %}
 {% endmacro %}

    {{ govukDetails({
      summaryText: "See full list of products",
      text: allProductsList(products)
    }) }}

  {% macro alertsInformation(alertsInfo) %}
    {% if dashboard.alertsInfo | length %}
      {% for alert in alertsInfo %}
        <h3>{{ alert.componentSlug }}</h3>
          <p>{{ alert.alertname }}</p>
      {% else %}
        <p> There are no active alerts for this product </p>
      {% endfor %}
    {% endif %}
  {% endmacro %}

    <div class="govuk-grid-row hmpps-miniSummaryWrapper govuk-!-margin-bottom-6">
      <div class="govuk-grid-column-one-third">
        {% if dashboard.alerts | length > 0 %}
          <div id="dashboard-alerts-popup" class="govuk-inset-text govuk-!-margin-bottom-4">
            <p class="govuk-!-font-weight-bold govuk-!-margin-bottom-1">Active alerts identified on one or more components</p>
            <p><a href="/alerts?environment=prod&team=' + team.encodedTeamName + '" class="govuk-link">See active alerts</a></p>
            <ul class="govuk-list govuk-list--bullet">
              {% for componentName in dashboard.alerts %}
                <li>
                  <a class="govuk-link" href="/components/{{ componentName.componentSlug }}">{{ componentName.componentSlug }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      </div>

      <div class="govuk-grid-column-one-third">
        {% if dashboard.veracodeVulnerabilityCount > 0 %}
          <div id="dashboard-veracode-popup" class="govuk-inset-text govuk-!-margin-bottom-4">
            <p class="govuk-!-font-weight-bold govuk-!-margin-bottom-1">Vulnerabilities identified in production environment</p>
            <p><strong>{{ dashboard.veracodeVulnerabilityCount }}</strong> very high and/or high vulnerabilities have been identified in the latest Veracode scan. <a class="govuk-link--no-visited-state" href="/veracode?&results=failed">See veracode results.</a></p>
            <ul class="govuk-list govuk-list--bullet">
              {% for componentName in dashboard.veracodeComponentName %}
                <li>
                  <a class="govuk-link" href="/components/{{ componentName }}">{{ componentName }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      </div>

      <div class="govuk-grid-column-one-third">
        {% if upgradeNeeded.length %}
          <div id="dashboard-upgrade-popup" class="govuk-inset-text govuk-!-margin-bottom-4">
            <p class="govuk-!-font-weight-bold govuk-!-margin-bottom-1">Components needing dependency upgrades identified</p>
            <ul class="govuk-list govuk-list--bullet">
              {% for componentName in upgradeNeeded %}
                <li>
                  <a class="govuk-link" href="/components/{{ componentName }}">{{ componentName }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      </div>
    </div>

    {% for product in dashboard.filteredProductsObject %}
      {{ govukSummaryList({
        card: {
          title: {
            text: product.name
          },
            actions: {
              items: [
                {
                  text: deleteButton(product.name)
                }
              ]
            }
        },
        rows: [
          {
             key: {
               text: 'Description'
             },
             value: {
               html: product.description
             }
          },
          {
             key: {
               text: "Components"
             },
             value: {
               html: componentsList(dashboard.component[loop.index0])
             }
          }
        ]
      }) }}
    {%  endfor %}
  </form>

  {% if dashboard.productsList.length == 0 %}
    {{ mojAlert({
      variant: "information",
      title: "You do not have any pinned products",
      showTitleAsHeading: true,
      dismissible: false,
      html: 'Click on the "add a product" button to add one.'
    }) }}
  {% endif %}

  {% else %}
    {{ mojAlert({
      variant: "information",
      title: "You are not able to use the dashboard without additional cookies",
      dismissible: false,
      html: 'You are not able to use the dashboard without additional cookies. If you would like to change your cookie preferences, you can do so here <a href="/cookies">Cookies</a>.'
    }) }}
  {% endif %}

{% endblock %}
<div class="banner">
  <p>Last successful data collection by  {{ jobName }} at {{ lastSuccessfulRun }}</p>
</div>
{% block bodyEnd %}
  <script type="module" src="/assets/frontendInit.js"></script>
  <script src="/assets/js/common.js"></script>
{% endblock %}

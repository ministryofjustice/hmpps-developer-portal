{% extends "../partials/layout.njk" %}

{% set pageTitle = applicationName + " - Components" %}
{% set mainClasses = "app-container govuk-body" %}

{% block content %}

{{ breadCrumb("Components", []) }}

<h1>Components</h1>
<p>
  {% if archived %}
    All archived components are displayed on this page. Click <a href="/components">here</a> for live components.
  {% else %}
    All live components are displayed on this page. Click <a href="/components?archived=true">here</a> for archived components.
  {% endif %}
</p>

<table id="componentsTable" class="stripe">
  <thead>
    <tr>
      <th>Name</th>
      <th>Product ID</th>
      <th>Product Name</th>
      <th>Portfolio</th>
      <th>GitHub Repository</th>
      <th>GitHub Admin Enforce branch protection</th>
      <th>Production Slack Channel</th>
      <th class="githubTeams">GitHub Teams</th>
      <th class="githubTeams">GitHub Admin Teams</th>
      <th class="githubTeams">GitHub Write Teams</th>
      <th class="githubTeams">GitHub Maintain Teams</th>
      <th class="archived">Archived</th>
      <th>App Insights Cloud Role Name</th>
      <th>App Insights Alerts Enabled</th>
      <th>Dependent Count</th>
      <th>IP Allowlist version</th>
    </tr>
  </thead>
  <tfoot>
    <tr>
      <th>Name</th>
      <th>Product ID</th>
      <th>Product Name</th>
      <th>Portfolio</th>
      <th>GitHub Repository</th>
      <th>GitHub Admin Enforce branch protection</th>
      <th>Production Slack Channel</th>
      <th class="githubTeams">GitHub Teams</th>
      <th class="githubTeams">GitHub Admin Teams</th>
      <th class="githubTeams">GitHub Write Teams</th>
      <th class="githubTeams">GitHub Maintain Teams</th>
      <th class="archived">Archived</th>
      <th>App Insights Cloud Role Name</th>
      <th>App Insights Alerts Enabled</th>
      <th>Dependent Count</th>
      <th>IP Allowlist version</th>
    </tr>
  </tfoot>
</table>
<div class="banner">
  <p>Last successful data collection by  {{ jobName }} at {{ lastSuccessfulRun }}</p>
</div>
{% endblock %}
